# Copy to .env in this folder on the VM — do not commit.
# Frontend-only vars (VITE_*) go in Netlify, not here.

# --- Required for HTTPS / reverse proxy ---
CADDY_DOMAIN=api.go-wind.com

# --- Required ---
MONGODB_URI=
DB_NAME=gowind
JWT_SECRET=
API_URL=https://api.go-wind.com
FRONTEND_URL=https://go-wind.com
NODE_ENV=production
PORT=3001

# Extra CORS origins (optional, comma-separated), e.g. preview Netlify URLs
# FRONTEND_ORIGINS=

# --- Google OAuth (required for Google login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin ---
ADMIN_EMAILS=

# --- Weather providers (recommended — same keys as on Render) ---
VISUALCROSSING_API_KEY=
METEOSOURCE_API_KEY=
OPENWEATHER_API_KEY=
MET_NORWAY_USER_AGENT=

# --- Weather cache (optional; defaults work fine) ---
WEATHER_CACHE_TTL_MS=3600000
WEATHER_CACHE_RADIUS_KM=1
WEATHER_MAX_CACHE_ENTRIES=500

# --- PostHog server-side (optional) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Stripe (optional; only if you use server-side Stripe) ---
# STRIPE_SECRET_KEY=
