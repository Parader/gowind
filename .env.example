MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/gowind?retryWrites=true&w=majority
DB_NAME=gowind
JWT_SECRET=replace-with-long-random-string

# Google OAuth (optional, for SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API / Frontend URLs (for CORS and OAuth redirects)
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
# Browser → API (Netlify / Vite). Production after Oracle migrate:
# VITE_API_URL=https://api.go-wind.com
# Public site URL for Open Graph / social previews (production domain with hyphen)
# Netlify also injects URL at build time; this overrides when set.
VITE_SITE_URL=https://go-wind.com

# GoWind (Vite loads this file from repo root via gowind/vite.config envDir)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_DONATE_URL=https://buy.stripe.com/your_payment_link_or_checkout_path
# VITE_DONATE_URL=https://example.com/donate

# API + Stripe server-side (never use VITE_ — secrets must not ship to the browser)
# STRIPE_SECRET_KEY=sk_test_...

# Weather cache (optional) — per-provider overrides: WEATHER_<PROVIDER>_RADIUS_KM, _TTL_MS, _LIMIT_DAILY
WEATHER_CACHE_TTL_MS=3600000
WEATHER_CACHE_RADIUS_KM=1
WEATHER_MAX_CACHE_ENTRIES=500
# Example per-provider (some APIs have ~1000/day limit):
# WEATHER_WEATHERAPI_LIMIT_DAILY=1000

# Visual Crossing Weather API (optional — adds another source for Go Times verification)
VISUALCROSSING_API_KEY=

# Meteosource Weather API (optional — adds another source for Go Times verification)
METEOSOURCE_API_KEY=

# OpenWeather API (optional — adds another source for Go Times verification, 5 day / 3h, ~1000/day free)
OPENWEATHER_API_KEY=

# MET Norway (optional — set provider=met-norway; User-Agent must include contact email or URL)
MET_NORWAY_USER_AGENT=TempestWeather/1.0 your@email.com

# Admin (comma-separated emails that can access /admin API stats)
ADMIN_EMAILS=

# PostHog analytics (optional — browser SDK, requires cookie consent)
# Use the Project API Key from PostHog → Project settings (starts with phc_)
# Local: set in repo root `.env` (Vite loads from parent dir via gowind/vite.config.ts)
# Netlify: Site settings → Environment variables (rebuild after adding)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# PostHog analytics (server-side — Render / API host env)
# Same project key works; used for share events from the API
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

