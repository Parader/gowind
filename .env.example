# =============================================================================
# GoWind monorepo env (copy to repo-root `.env` for local API + Vite)
# Vite loads this file via gowind/vite.config.ts envDir = parent.
# Production API (Oracle): use api/deploy/oracle/.env — see that .env.example.
# Production frontend (Netlify): set VITE_* there and redeploy.
# =============================================================================

# --- Core API (required) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/gowind?retryWrites=true&w=majority
DB_NAME=gowind
JWT_SECRET=replace-with-long-random-string
NODE_ENV=development
PORT=3001

# Google OAuth (optional locally; required in prod for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API / Frontend URLs (CORS + OAuth redirects)
# Local:
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
# Production (Oracle + Netlify) examples:
# API_URL=https://api.go-wind.com
# FRONTEND_URL=https://go-wind.com
# Extra CORS origins (optional, comma-separated), e.g. Netlify preview URLs
# FRONTEND_ORIGINS=

# Admin (comma-separated emails for /admin)
ADMIN_EMAILS=

# --- Weather ---
# Cache (optional; defaults work fine)
WEATHER_CACHE_TTL_MS=3600000
WEATHER_CACHE_RADIUS_KM=1
WEATHER_MAX_CACHE_ENTRIES=500
# Per-provider overrides: WEATHER_<PROVIDER>_RADIUS_KM, _TTL_MS, _LIMIT_DAILY
# WEATHER_WEATHERAPI_LIMIT_DAILY=1000

# Optional forecast sources (included in Go Times when keys are set)
VISUALCROSSING_API_KEY=
METEOSOURCE_API_KEY=
OPENWEATHER_API_KEY=
# MET Norway User-Agent must include contact email or URL
MET_NORWAY_USER_AGENT=TempestWeather/1.0 your@email.com

# --- PostHog (API / server-side) ---
# Same Project API Key (phc_...) as the browser key
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Stripe (API only — never use VITE_ for secrets) ---
# STRIPE_SECRET_KEY=sk_test_...

# =============================================================================
# Frontend (Vite) — local `.env` and/or Netlify env
# =============================================================================

# Browser → API base URL
# Local default is http://localhost:3001 if unset
# Production (after Oracle migrate):
# VITE_API_URL=https://api.go-wind.com
VITE_API_URL=

# Public site URL for Open Graph / social previews
VITE_SITE_URL=https://go-wind.com

# PostHog browser SDK (requires cookie consent)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Stripe / donate (public)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_DONATE_URL=https://buy.stripe.com/your_payment_link
# VITE_DONATE_URL=https://example.com/donate

# =============================================================================
# Oracle Always Free deploy only (api/deploy/oracle/.env — not used by Vite)
# =============================================================================
# CADDY_DOMAIN=api.go-wind.com
